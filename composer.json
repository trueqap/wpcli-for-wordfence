{
    "name": "trueqap/wpcli-for-wordfence",
    "description": "WP-CLI commands and WordPress Abilities API integration for Wordfence Security - manage scans, issues, firewall, and license from CLI and REST API",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "trueqap",
            "homepage": "https://github.com/trueqap"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "wp-cli/wp-cli": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "WordfenceCLI\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
